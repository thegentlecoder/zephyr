config AUXDISPLAY_ST_SLCD
	bool "ST MCU SLCD display driver"
	default y
	depends on DT_HAS_ST_SLCD_ENABLED
	help
	  Enable STMicroelectronics MCU SLCD (Segmented LCD) auxdisplay driver.
	  Provides the standard auxdisplay API for ST MCU SLCD hardware,
	  handling both hardware initialization and the display panel layer
	  in a single unified driver.
