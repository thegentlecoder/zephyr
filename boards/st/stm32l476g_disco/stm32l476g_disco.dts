/dts-v1/;
#include <st/l4/stm32l476Xg.dtsi>
#include <st/l4/stm32l476v(c-e-g)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "STMicroelectronics STM32L476G-DISCO board";
	compatible = "st,stm32l476g-disco";

	chosen {
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	leds {
		compatible = "gpio-leds";

		green_led_4: led_4 {
			gpios = <&gpiob 2 GPIO_ACTIVE_HIGH>;
			label = "User LD4";
		};

		green_led_5: led_5 {
			gpios = <&gpioe 8 GPIO_ACTIVE_HIGH>;
			label = "User LD5";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		joy_center: joystick_center {
			label = "joystick center";
			gpios = <&gpioa 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_ENTER>;
		};

		joy_down: joystick_down {
			label = "joystick down";
			gpios = <&gpioa 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_DOWN>;
		};

		joy_up: joystick_up {
			label = "joystick up";
			gpios = <&gpioa 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_UP>;
		};

		joy_left: joystick_left {
			label = "joystick left";
			gpios = <&gpioa 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_LEFT>;
		};

		joy_right: joystick_right {
			label = "joystick right";
			gpios = <&gpioa 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_RIGHT>;
		};
	};

	aliases {
		led0 = &green_led_4;
		sw0 = &joy_center;
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hsi {
	status = "okay";
};

&pll {
	div-m = <1>;
	mul-n = <20>;
	div-p = <7>;
	div-q = <2>;
	div-r = <4>;
	clocks = <&clk_hsi>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(80)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&rtc {
	clocks = <&rcc STM32_CLOCK(APB1, 28)>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";

	backup_regs {
		status = "okay";
	};
};

/ {
	chosen {
		zephyr,auxdisplay = &glass_lcd;
	};

	/* We target the core SoC bus to declare the missing peripheral hardware block */
	soc {
		glass_lcd: lcd@40002400 {
			compatible = "st,stm32-glass-lcd";
			status = "okay";

			reg = <0x40002400 0x400>;

			clocks = <&rcc STM32_CLOCK(APB1, 24)>;

			pinctrl-0 = <&lcd_seg23_pa6 &lcd_seg0_pa7 &lcd_com0_pa8
				     &lcd_com1_pa9 &lcd_com2_pa10 &lcd_seg10_pa15
				     &lcd_seg21_pb0 &lcd_seg2_pb1 &lcd_seg11_pb4
				     &lcd_seg12_pb5 &lcd_com3_pb9 &lcd_seg20_pb12
				     &lcd_seg3_pb13 &lcd_seg19_pb14 &lcd_seg4_pb15
				     &lcd_vlcd_pc3 &lcd_seg22_pc4 &lcd_seg1_pc5
				     &lcd_seg14_pc6 &lcd_seg9_pc7 &lcd_seg13_pc8
				     &lcd_seg18_pd8 &lcd_seg5_pd9 &lcd_seg17_pd10 &lcd_seg6_pd11
				     &lcd_seg16_pd12 &lcd_seg7_pd13 &lcd_seg15_pd14 &lcd_seg8_pd15>;
			pinctrl-names = "default";

			columns = <6>;
			rows = <1>;
		};
	};
};

&pinctrl {
	/omit-if-no-ref/ lcd_seg23_pa6: lcd_seg23_pa6 { pinmux = <STM32_PINMUX('A', 6, AF11)>; };
	/omit-if-no-ref/ lcd_seg0_pa7: lcd_seg0_pa7 { pinmux = <STM32_PINMUX('A', 7, AF11)>; };
	/omit-if-no-ref/ lcd_com0_pa8: lcd_com0_pa8 { pinmux = <STM32_PINMUX('A', 8, AF11)>; };
	/omit-if-no-ref/ lcd_com1_pa9: lcd_com1_pa9 { pinmux = <STM32_PINMUX('A', 9, AF11)>; };
	/omit-if-no-ref/ lcd_com2_pa10: lcd_com2_pa10 { pinmux = <STM32_PINMUX('A', 10, AF11)>; };
	/omit-if-no-ref/ lcd_seg10_pa15: lcd_seg10_pa15 { pinmux = <STM32_PINMUX('A', 15, AF11)>; };

	/omit-if-no-ref/ lcd_seg21_pb0: lcd_seg21_pb0 { pinmux = <STM32_PINMUX('B', 0, AF11)>; };
	/omit-if-no-ref/ lcd_seg2_pb1: lcd_seg2_pb1 { pinmux = <STM32_PINMUX('B', 1, AF11)>; };
	/omit-if-no-ref/ lcd_seg11_pb4: lcd_seg11_pb4 { pinmux = <STM32_PINMUX('B', 4, AF11)>; };
	/omit-if-no-ref/ lcd_seg12_pb5: lcd_seg12_pb5 { pinmux = <STM32_PINMUX('B', 5, AF11)>; };
	/omit-if-no-ref/ lcd_com3_pb9: lcd_com3_pb9 { pinmux = <STM32_PINMUX('B', 9, AF11)>; };
	/omit-if-no-ref/ lcd_seg20_pb12: lcd_seg20_pb12 { pinmux = <STM32_PINMUX('B', 12, AF11)>; };
	/omit-if-no-ref/ lcd_seg3_pb13: lcd_seg3_pb13 { pinmux = <STM32_PINMUX('B', 13, AF11)>; };
	/omit-if-no-ref/ lcd_seg19_pb14: lcd_seg19_pb14 { pinmux = <STM32_PINMUX('B', 14, AF11)>; };
	/omit-if-no-ref/ lcd_seg4_pb15: lcd_seg4_pb15 { pinmux = <STM32_PINMUX('B', 15, AF11)>; };

	/omit-if-no-ref/ lcd_vlcd_pc3: lcd_vlcd_pc3 { pinmux = <STM32_PINMUX('C', 3, AF11)>; };
	/omit-if-no-ref/ lcd_seg22_pc4: lcd_seg22_pc4 { pinmux = <STM32_PINMUX('C', 4, AF11)>; };
	/omit-if-no-ref/ lcd_seg1_pc5: lcd_seg1_pc5 { pinmux = <STM32_PINMUX('C', 5, AF11)>; };
	/omit-if-no-ref/ lcd_seg14_pc6: lcd_seg14_pc6 { pinmux = <STM32_PINMUX('C', 6, AF11)>; };
	/omit-if-no-ref/ lcd_seg9_pc7: lcd_seg9_pc7 { pinmux = <STM32_PINMUX('C', 7, AF11)>; };
	/omit-if-no-ref/ lcd_seg13_pc8: lcd_seg13_pc8 { pinmux = <STM32_PINMUX('C', 8, AF11)>; };

	/omit-if-no-ref/ lcd_seg18_pd8: lcd_seg18_pd8 { pinmux = <STM32_PINMUX('D', 8, AF11)>; };
	/omit-if-no-ref/ lcd_seg5_pd9: lcd_seg5_pd9 { pinmux = <STM32_PINMUX('D', 9, AF11)>; };
	/omit-if-no-ref/ lcd_seg17_pd10: lcd_seg17_pd10 { pinmux = <STM32_PINMUX('D', 10, AF11)>; };
	/omit-if-no-ref/ lcd_seg6_pd11: lcd_seg6_pd11 { pinmux = <STM32_PINMUX('D', 11, AF11)>; };
	/omit-if-no-ref/ lcd_seg16_pd12: lcd_seg16_pd12 { pinmux = <STM32_PINMUX('D', 12, AF11)>; };
	/omit-if-no-ref/ lcd_seg7_pd13: lcd_seg7_pd13 { pinmux = <STM32_PINMUX('D', 13, AF11)>; };
	/omit-if-no-ref/ lcd_seg15_pd14: lcd_seg15_pd14 { pinmux = <STM32_PINMUX('D', 14, AF11)>; };
	/omit-if-no-ref/ lcd_seg8_pd15: lcd_seg8_pd15 { pinmux = <STM32_PINMUX('D', 15, AF11)>; };
};
